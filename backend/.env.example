# Backend Environment Variables Template
# Copy this file to .env and fill in actual values
# NEVER commit .env file to version control

# MongoDB connection URL
# Recommended: MongoDB Atlas for production
# Format: mongodb+srv://username:password@cluster.mongodb.net/
MONGO_URL=mongodb://localhost:27017

# Database name
DB_NAME=coner_db

# JWT Secret for token signing (generate a strong random key)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Minimum 32 characters recommended
JWT_SECRET=change-me-to-a-strong-secret-key

# CORS Origins (comma-separated list)
# In development: http://localhost:3000
# In production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# Optional: API Configuration defaults
# These can also be set via the admin panel
API_URL=
API_KEY=
API_TIMEOUT=30
